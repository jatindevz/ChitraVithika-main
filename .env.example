# ══════════════════════════════════════════════════════
# ChitraVithika — Environment Variables
# Copy this file to .env and fill in your values.
# On Vercel: set these in Settings → Environment Variables.
# ══════════════════════════════════════════════════════

# ─── MongoDB Atlas (REQUIRED) ────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/chitravithika?retryWrites=true&w=majority
MONGO_URI=

# ─── Authentication Secret ───────────────────────────
# Used for signing session tokens. Set a strong random string.
AUTH_TOKEN_SECRET=

# ─── Firebase Google Sign-In (OPTIONAL) ──────────────
# Only needed if you want Google Sign-In support.
# Get these from Firebase Console → Project Settings → General → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Server Settings ─────────────────────────────────
PORT=3000
NODE_ENV=development
# PUBLIC_ORIGIN=https://your-vercel-app.vercel.app
